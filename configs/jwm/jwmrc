<?xml version="1.0"?>
<JWM>

    <!-- hackOS: JWM config, coherente en estetica/keybinds con el resto -->

    <RootMenu height="28" onroot="12">
        <Program icon="terminal" label="Terminal">sakura</Program>
        <Program icon="folder" label="Archivos">pcmanfm</Program>
        <Program icon="web-browser" label="Navegador">__HACKOS_BROWSER__</Program>
        <Program icon="accessories-text-editor" label="Editor">pluma</Program>
        <Separator/>
        <Program icon="system-search" label="Lanzador (rofi)">rofi -show drun</Program>
        <Separator/>
        <Restart label="Reiniciar JWM" icon="restart"/>
        <Exit label="Cerrar sesion" icon="logout" confirm="true"/>
    </RootMenu>

    <TrayStyle>
        <Font>JetBrainsMono Nerd Font:size=10</Font>
        <Foreground>#d6dbe0</Foreground>
        <Background>#101418</Background>
    </TrayStyle>

    <WindowStyle>
        <Font>JetBrainsMono Nerd Font:bold:size=10</Font>
        <Width>2</Width>
        <Height>26</Height>
        <Active>
            <Foreground>#EA0057</Foreground>
            <Background>#101418</Background>
        </Active>
        <Foreground>#8a9099</Foreground>
        <Background>#181c20</Background>
    </WindowStyle>

    <Tray x="0" y="-1" height="30" autohide="off">
        <TrayButton icon="jwm">root:1</TrayButton>
        <Pager labeled="true"/>
        <TaskList maxwidth="200"/>
        <Dock/>
        <Clock format="%H:%M %d/%m"/>
    </Tray>

    <Desktops width="5" height="1">
        <Background type="solid">#0b0e10</Background>
        <Desktop name="Term"/>
        <Desktop name="Web"/>
        <Desktop name="Code"/>
        <Desktop name="Files"/>
        <Desktop name="Sys"/>
    </Desktops>

    <DoubleClickSpeed>400</DoubleClickSpeed>
    <DoubleClickDelta>2</DoubleClickDelta>
    <FocusModel>click</FocusModel>
    <SnapMode distance="10">border</SnapMode>
    <MoveMode>opaque</MoveMode>
    <ResizeMode>opaque</ResizeMode>

    <StartupCommand>picom -b --config ~/.config/picom/picom.conf</StartupCommand>
    <StartupCommand>dunst</StartupCommand>
    <StartupCommand>nm-applet</StartupCommand>
    <StartupCommand>feh --bg-fill --randomize ~/Pictures/hackos-wallpapers/*</StartupCommand>

    <!-- Atajos: mask="4" = tecla Super/Windows (mod4), confirmado con jwm -p -->
    <Key mask="4" key="t">exec:sakura</Key>
    <Key mask="4" key="Return">exec:sakura</Key>
    <Key mask="4" key="e">exec:pcmanfm</Key>
    <Key mask="4" key="w">exec:__HACKOS_BROWSER__</Key>
    <Key mask="4" key="c">exec:pluma</Key>
    <Key mask="4" key="d">exec:rofi -show drun</Key>
    <Key mask="4" key="space">exec:rofi -show run</Key>
    <Key mask="4" key="q">close</Key>
    <Key mask="4" key="f">maximize</Key>
    <Key mask="4S" key="q">exit</Key>
    <Key mask="A" key="Tab">next</Key>
    <Key mask="4" key="Left">ldesktop</Key>
    <Key mask="4" key="Right">rdesktop</Key>

</JWM>
