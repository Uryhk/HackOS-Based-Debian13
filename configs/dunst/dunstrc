[global]
    monitor = 0
    follow = mouse
    width = 320
    height = 200
    origin = top-right
    offset = 16x48
    scale = 0
    notification_limit = 5
    indicate_hidden = yes
    transparency = 10
    separator_height = 2
    padding = 12
    horizontal_padding = 16
    text_icon_padding = 10
    frame_width = 2
    frame_color = "#EA0057"
    separator_color = frame
    sort = yes
    idle_threshold = 120
    font = JetBrainsMono Nerd Font 10
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

[urgency_low]
    background = "#0A0A0A"
    foreground = "#8a9099"
    timeout = 4

[urgency_normal]
    background = "#0A0A0A"
    foreground = "#F0F0F0"
    timeout = 8

[urgency_critical]
    background = "#0A0A0A"
    foreground = "#F0F0F0"
    frame_color = "#ff5555"
    timeout = 0
